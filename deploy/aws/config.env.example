# ─────────────────────────────────────────────────────────────
# deploy/aws/config.env  — copy from config.env.example and fill in.
# This file CONTAINS SECRETS and is gitignored. Never commit it.
# ─────────────────────────────────────────────────────────────

# --- AWS account / region -------------------------------------
AWS_REGION=eu-west-3
# Optional named profile (leave empty to use default credentials)
AWS_PROFILE=

# --- Networking -----------------------------------------------
# Existing EC2 keypair name (used for SSH/debug; not required to run).
KEY_NAME=
# Leave SG_ID empty to auto-create "flowise-training-sg" in the default VPC.
SG_ID=
# Restrict SSH to your IP ideally, e.g. 1.2.3.4/32
SSH_CIDR=0.0.0.0/0
# Who can reach Flowise on :3000 (learners). 0.0.0.0/0 = anyone.
APP_CIDR=0.0.0.0/0
# Optional explicit subnet (public). Leave empty to use the default VPC subnet.
SUBNET_ID=

# --- Instances ------------------------------------------------
INSTANCE_TYPE=t3.medium      # t3.large (8GB) is more comfortable
COUNT=17
ROOT_VOLUME_GB=30
UBUNTU_VERSION=22.04
AMI_NAME_PREFIX=flowise-training
TAG_KEY=training
TAG_VALUE=flowise-j2026

# --- Repo baked into the AMI ----------------------------------
REPO_URL=https://github.com/ssime-git/deloitte-no-code-flowise.git
REPO_BRANCH=main

# --- Secrets baked into the AMI .env --------------------------
# These are written to .env on the baked image. Keep the AMI PRIVATE.
POSTGRES_PASSWORD=changeme_secure_password
OPENAI_GATEWAY_API_KEY=
OPENAI_GATEWAY_BASE_URL=https://ai-gateway.liora.tech/v1
OPENAI_GATEWAY_MODEL=gpt-4.1-nano
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=sonnet-4-6

# --- Flowise login (shared across all 17 instances) -----------
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=changeme_admin_password
