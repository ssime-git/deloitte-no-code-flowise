{
  "$schema": "https://btca.dev/btca.schema.json",
  "resources": [
    {
      "type": "git",
      "name": "flowise",
      "url": "https://github.com/FlowiseAI/Flowise",
      "branch": "main",
      "searchPaths": [
        "packages/api-documentation",
        "packages/server",
        "packages/ui/src/api"
      ]
    }
  ],
  "model": "claude-haiku-4-5",
  "provider": "openai-compat",
  "providerOptions": {
    "openai-compat": {
      "baseURL": "http://localhost:4000/v1",
      "name": "litellm-proxy"
    }
  }
}